    "tokenColors": [
        {
            "name": "Comments",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#56509a",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Keywords",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.operator.new",
                "keyword.operator.expression",
                "keyword.operator.logical.python",
                "storage.type.class",
                "storage.type.function",
                "storage.type.extends"
            ],
            "settings": {
                "foreground": "#f72585"
            }
        },
        {
            "name": "Storage modifiers",
            "scope": [
                "storage.modifier",
                "keyword.control.flow",
                "keyword.control.return",
                "keyword.control.import",
                "keyword.control.export",
                "keyword.control.from",
                "keyword.control.as"
            ],
            "settings": {
                "foreground": "#b5179e"
            }
        },
        {
            "name": "Types and classes",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.other.inherited-class",
                "support.class",
                "support.type",
                "meta.return-type",
                "storage.type.primitive"
            ],
            "settings": {
                "foreground": "#b5179e"
            }
        },
        {
            "name": "Functions and methods",
            "scope": [
                "entity.name.function",
                "meta.function-call entity.name.function",
                "support.function",
                "meta.method-call entity.name.function"
            ],
            "settings": {
                "foreground": "#4895ef"
            }
        },
        {
            "name": "Function parameters",
            "scope": [
                "variable.parameter",
                "meta.function.parameter variable.other"
            ],
            "settings": {
                "foreground": "#4895ef",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Variables",
            "scope": [
                "variable",
                "variable.other",
                "variable.other.readwrite",
                "meta.definition.variable"
            ],
            "settings": {
                "foreground": "#d4d0f0"
            }
        },
        {
            "name": "Constants and enum members",
            "scope": [
                "variable.other.constant",
                "variable.other.enummember",
                "support.constant"
            ],
            "settings": {
                "foreground": "#7209b7"
            }
        },
        {
            "name": "Strings",
            "scope": [
                "string",
                "string.quoted",
                "string.template"
            ],
            "settings": {
                "foreground": "#4cc9f0"
            }
        },
        {
            "name": "String escape sequences",
            "scope": [
                "constant.character.escape",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#4895ef"
            }
        },
        {
            "name": "Template literal punctuation",
            "scope": [
                "punctuation.definition.template-expression",
                "punctuation.section.embedded"
            ],
            "settings": {
                "foreground": "#f72585"
            }
        },
        {
            "name": "Numbers",
            "scope": [
                "constant.numeric",
                "constant.numeric.integer",
                "constant.numeric.float"
            ],
            "settings": {
                "foreground": "#7209b7"
            }
        },
        {
            "name": "Boolean and null",
            "scope": [
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined",
                "constant.language.nan"
            ],
            "settings": {
                "foreground": "#7209b7",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Object properties",
            "scope": [
                "variable.other.object.property",
                "meta.object-literal.key",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#4361ee"
            }
        },
        {
            "name": "Object member access",
            "scope": [
                "variable.other.property",
                "meta.property.object"
            ],
            "settings": {
                "foreground": "#4361ee"
            }
        },
        {
            "name": "Operators",
            "scope": [
                "keyword.operator",
                "keyword.operator.arithmetic",
                "keyword.operator.assignment",
                "keyword.operator.comparison",
                "keyword.operator.logical",
                "keyword.operator.bitwise",
                "keyword.operator.ternary",
                "keyword.operator.optional"
            ],
            "settings": {
                "foreground": "#b5179e"
            }
        },
        {
            "name": "Punctuation",
            "scope": [
                "punctuation",
                "punctuation.separator",
                "punctuation.terminator",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#6060a0"
            }
        },
        {
            "name": "Decorators and annotations",
            "scope": [
                "meta.decorator",
                "punctuation.decorator",
                "entity.name.function.decorator"
            ],
            "settings": {
                "foreground": "#f72585",
                "fontStyle": "italic"
            }
        },
        {
            "name": "TypeScript type annotations",
            "scope": [
                "meta.type.annotation",
                "meta.type.parameters",
                "entity.name.type.ts",
                "entity.name.type.module"
            ],
            "settings": {
                "foreground": "#b5179e"
            }
        },
        {
            "name": "TypeScript interfaces",
            "scope": [
                "entity.name.type.interface"
            ],
            "settings": {
                "foreground": "#b5179e",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Import / module paths",
            "scope": [
                "string.quoted.double.import",
                "string.quoted.single.import",
                "entity.name.module"
            ],
            "settings": {
                "foreground": "#4cc9f0"
            }
        },
        {
            "name": "HTML tags",
            "scope": [
                "entity.name.tag",
                "meta.tag"
            ],
            "settings": {
                "foreground": "#f72585"
            }
        },
        {
            "name": "HTML attributes",
            "scope": [
                "entity.other.attribute-name",
                "meta.tag entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#4361ee"
            }
        },
        {
            "name": "HTML attribute values",
            "scope": [
                "string.quoted.double.html",
                "string.quoted.single.html"
            ],
            "settings": {
                "foreground": "#4cc9f0"
            }
        },
        {
            "name": "HTML punctuation",
            "scope": [
                "punctuation.definition.tag",
                "punctuation.definition.tag.html"
            ],
            "settings": {
                "foreground": "#560bad"
            }
        },
        {
            "name": "CSS selectors",
            "scope": [
                "entity.name.tag.css",
                "entity.other.attribute-name.css",
                "entity.other.attribute-name.class.css",
                "entity.other.attribute-name.id.css",
                "entity.other.attribute-name.pseudo-class.css",
                "entity.other.attribute-name.pseudo-element.css"
            ],
            "settings": {
                "foreground": "#f72585"
            }
        },
        {
            "name": "CSS properties",
            "scope": [
                "support.type.property-name.css",
                "support.type.property-name.scss",
                "support.type.property-name.less"
            ],
            "settings": {
                "foreground": "#4361ee"
            }
        },
        {
            "name": "CSS property values",
            "scope": [
                "support.constant.property-value.css",
                "meta.property-value.css",
                "support.constant.color.w3c-standard-color-name.css"
            ],
            "settings": {
                "foreground": "#4cc9f0"
            }
        },
        {
            "name": "CSS custom properties",
            "scope": [
                "variable.css",
                "variable.argument.css",
                "support.type.custom-property.name.css"
            ],
            "settings": {
                "foreground": "#4895ef"
            }
        },
        {
            "name": "CSS at-rules",
            "scope": [
                "keyword.control.at-rule.css",
                "keyword.control.at-rule.scss"
            ],
            "settings": {
                "foreground": "#b5179e"
            }
        },
        {
            "name": "CSS units and numbers",
            "scope": [
                "constant.numeric.css",
                "keyword.other.unit.css"
            ],
            "settings": {
                "foreground": "#7209b7"
            }
        },
        {
            "name": "JSON keys",
            "scope": [
                "support.type.property-name.json",
                "string.json support.type.property-name"
            ],
            "settings": {
                "foreground": "#4361ee"
            }
        },
        {
            "name": "JSON string values",
            "scope": [
                "string.quoted.double.json"
            ],
            "settings": {
                "foreground": "#4cc9f0"
            }
        },
        {
            "name": "Markdown headings",
            "scope": [
                "markup.heading",
                "markup.heading.markdown",
                "entity.name.section.markdown",
                "punctuation.definition.heading.markdown"
            ],
            "settings": {
                "foreground": "#f72585",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markdown bold",
            "scope": [
                "markup.bold",
                "markup.bold.markdown"
            ],
            "settings": {
                "foreground": "#4895ef",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markdown italic",
            "scope": [
                "markup.italic",
                "markup.italic.markdown"
            ],
            "settings": {
                "foreground": "#4895ef",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markdown code",
            "scope": [
                "markup.inline.raw",
                "markup.raw.block"
            ],
            "settings": {
                "foreground": "#4cc9f0"
            }
        },
        {
            "name": "Markdown links",
            "scope": [
                "markup.underline.link",
                "string.other.link.title.markdown"
            ],
            "settings": {
                "foreground": "#4361ee"
            }
        },
        {
            "name": "Markdown blockquote",
            "scope": [
                "markup.quote",
                "markup.quote.markdown"
            ],
            "settings": {
                "foreground": "#56509a",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markdown list punctuation",
            "scope": [
                "punctuation.definition.list.begin.markdown"
            ],
            "settings": {
                "foreground": "#b5179e"
            }
        },
        {
            "name": "YAML keys",
            "scope": [
                "entity.name.tag.yaml",
                "string.unquoted.plain.out.yaml entity.name.tag"
            ],
            "settings": {
                "foreground": "#4361ee"
            }
        },
        {
            "name": "YAML values",
            "scope": [
                "string.unquoted.plain.out.yaml",
                "string.quoted.single.yaml",
                "string.quoted.double.yaml"
            ],
            "settings": {
                "foreground": "#4cc9f0"
            }
        },
        {
            "name": "YAML anchors and aliases",
            "scope": [
                "variable.other.alias.yaml",
                "entity.name.label.yaml",
                "punctuation.definition.alias.yaml",
                "punctuation.definition.anchor.yaml"
            ],
            "settings": {
                "foreground": "#b5179e"
            }
        },
        {
            "name": "Invalid / deprecated",
            "scope": [
                "invalid",
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#f72585",
                "fontStyle": "strikethrough"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "class": "#b5179e",
        "interface": {
            "foreground": "#b5179e",
            "italic": true
        },
        "enum": "#7209b7",
        "enumMember": {
            "foreground": "#7209b7",
            "italic": true
        },
        "function": "#4895ef",
        "method": "#4895ef",
        "parameter": {
            "foreground": "#4895ef",
            "italic": true
        },
        "variable": "#d4d0f0",
        "variable.readonly": "#7209b7",
        "property": "#4361ee",
        "property.readonly": {
            "foreground": "#4361ee",
            "italic": true
        },
        "type": "#b5179e",
        "typeParameter": {
            "foreground": "#b5179e",
            "italic": true
        },
        "namespace": "#560bad",
        "keyword": "#f72585",
        "modifier": "#b5179e",
        "string": "#4cc9f0",
        "number": "#7209b7",
        "regexp": "#4895ef",
        "operator": "#b5179e",
        "decorator": {
            "foreground": "#f72585",
            "italic": true
        },
        "comment": {
            "foreground": "#56509a",
            "italic": true
        }
    }
}